    // upload_data[13] = ((int32_t)(winch->pose->euler[2] * 1000.0f)) >> 24;

    // upload_data[14] = ((int32_t)(winch->CAN1_M2006[0]->now_pos * 1000.0f)) & 0x000000FF;
    // upload_data[15] = (((int32_t)(winch->CAN1_M2006[0]->now_pos * 1000.0f)) & 0x0000FF00) >> 8;
    // upload_data[16] = (((int32_t)(winch->CAN1_M2006[0]->now_pos * 1000.0f)) & 0x00FF0000) >> 16;
    // upload_data[17] = ((int32_t)(winch->CAN1_M2006[0]->now_pos * 1000.0f)) >> 24;

    // upload_data[18] = ((int32_t)(winch->CAN1_M2006[1]->now_pos * 1000.0f)) & 0x000000FF;
    // upload_data[19] = (((int32_t)(winch->CAN1_M2006[1]->now_pos * 1000.0f)) & 0x0000FF00) >> 8;
    // upload_data[20] = (((int32_t)(winch->CAN1_M2006[1]->now_pos * 1000.0f)) & 0x00FF0000) >> 16;
    // upload_data[21] = ((int32_t)(winch->CAN1_M2006[1]->now_pos * 1000.0f)) >> 24;

    // upload_data[22] = ((int32_t)(winch->CAN1_M2006[2]->now_pos * 1000.0f)) & 0x000000FF;
    // upload_data[23] = (((int32_t)(winch->CAN1_M2006[2]->now_pos * 1000.0f)) & 0x0000FF00) >> 8;
    // upload_data[24] = (((int32_t)(winch->CAN1_M2006[2]->now_pos * 1000.0f)) & 0x00FF0000) >> 16;
    // upload_data[25] = ((int32_t)(winch->CAN1_M2006[2]->now_pos * 1000.0f)) >> 24;

    // upload_data[26] = ((int32_t)(winch->CAN1_M2006[3]->now_pos * 1000.0f)) & 0x000000FF;
    // upload_data[27] = (((int32_t)(winch->CAN1_M2006[3]->now_pos * 1000.0f)) & 0x0000FF00) >> 8;
    // upload_data[28] = (((int32_t)(winch->CAN1_M2006[3]->now_pos * 1000.0f)) & 0x00FF0000) >> 16;
    // upload_data[29] = ((int32_t)(winch->CAN1_M2006[3]->now_pos * 1000.0f)) >> 24;

    // upload_data[30] = ((int32_t)(winch->CAN1_M2006[4]->now_pos * 1000.0f)) & 0x000000FF;
    // upload_data[31] = (((int32_t)(winch->CAN1_M2006[4]->now_pos * 1000.0f)) & 0x0000FF00) >> 8;
    // upload_data[32] = (((int32_t)(winch->CAN1_M2006[4]->now_pos * 1000.0f)) & 0x00FF0000) >> 16;
    // upload_data[33] = ((int32_t)(winch->CAN1_M2006[4]->now_pos * 1000.0f)) >> 24;

    upload_data[2] = (wheel->pwm[0]) & 0x000000FF;
    upload_data[3] = ((wheel->pwm[0]) & 0x0000FF00) >> 8;
    upload_data[4] = (wheel->pwm[1]) & 0x000000FF;
    upload_data[5] = ((wheel->pwm[1]) & 0x0000FF00) >> 8;

    upload_data[6] = (wheel->pwm[2]) & 0x000000FF;
    upload_data[7] = ((wheel->pwm[2]) & 0x0000FF00) >> 8;
    upload_data[8] = (wheel->pwm[3]) & 0x000000FF;
    upload_data[9] = ((wheel->pwm[3]) & 0x0000FF00) >> 8;

    upload_data[10] = ((int32_t)(wheel->wheel_motor[0]->filtered_speed * 1000.0f)) & 0x000000FF;
    upload_data[11] = (((int32_t)(wheel->wheel_motor[0]->filtered_speed * 1000.0f)) & 0x0000FF00) >> 8;
    upload_data[12] = (((int32_t)(wheel->wheel_motor[0]->filtered_speed * 1000.0f)) & 0x00FF0000) >> 16;
    upload_data[13] = ((int32_t)(wheel->wheel_motor[0]->filtered_speed * 1000.0f)) >> 24;

    //电机转角（前三路：直接使用 data_process 的 now_pos）
    upload_data[14] = ((int32_t)(wheel->wheel_motor[1]->filtered_speed * 1000.0f)) & 0x000000FF;
    upload_data[15] = (((int32_t)(wheel->wheel_motor[1]->filtered_speed * 1000.0f)) & 0x0000FF00) >> 8;
    upload_data[16] = (((int32_t)(wheel->wheel_motor[1]->filtered_speed * 1000.0f)) & 0x00FF0000) >> 16;
    upload_data[17] = ((int32_t)(wheel->wheel_motor[1]->filtered_speed * 1000.0f)) >> 24;

    upload_data[18] = ((int32_t)(wheel->wheel_motor[2]->filtered_speed * 1000.0f)) & 0x000000FF;
    upload_data[19] = (((int32_t)(wheel->wheel_motor[2]->filtered_speed * 1000.0f)) & 0x0000FF00) >> 8;
    upload_data[20] = (((int32_t)(wheel->wheel_motor[2]->filtered_speed * 1000.0f)) & 0x00FF0000) >> 16;
    upload_data[21] = ((int32_t)(wheel->wheel_motor[2]->filtered_speed * 1000.0f)) >> 24;

    upload_data[22] = ((int32_t)(wheel->wheel_motor[3]->filtered_speed * 1000.0f)) & 0x000000FF;
    upload_data[23] = (((int32_t)(wheel->wheel_motor[3]->filtered_speed * 1000.0f)) & 0x0000FF00) >> 8;
    upload_data[24] = (((int32_t)(wheel->wheel_motor[3]->filtered_speed * 1000.0f)) & 0x00FF0000) >> 16;
    upload_data[25] = ((int32_t)(wheel->wheel_motor[3]->filtered_speed * 1000.0f)) >> 24;

    upload_data[26] = ((int32_t)(winch->CAN1_M2006[3]->now_pos * 1000.0f)) & 0x000000FF;
    upload_data[27] = (((int32_t)(winch->CAN1_M2006[3]->now_pos * 1000.0f)) & 0x0000FF00) >> 8;
    upload_data[28] = (((int32_t)(winch->CAN1_M2006[3]->now_pos * 1000.0f)) & 0x00FF0000) >> 16;
    upload_data[29] = ((int32_t)(winch->CAN1_M2006[3]->now_pos * 1000.0f)) >> 24;

    upload_data[30] = ((int32_t)(winch->CAN1_M2006[4]->now_pos * 1000.0f)) & 0x000000FF;
    upload_data[31] = (((int32_t)(winch->CAN1_M2006[4]->now_pos * 1000.0f)) & 0x0000FF00) >> 8;
    upload_data[32] = (((int32_t)(winch->CAN1_M2006[4]->now_pos * 1000.0f)) & 0x00FF0000) >> 16;
    upload_data[33] = ((int32_t)(winch->CAN1_M2006[4]->now_pos * 1000.0f)) >> 24;

    //姿态角速度
    upload_data[34] = ((int32_t)(winch->pose->omega[0] * 1000.0f)) & 0x000000FF;
    upload_data[35] = (((int32_t)(winch->pose->omega[0] * 1000.0f)) & 0x0000FF00) >> 8;
    upload_data[36] = (((int32_t)(winch->pose->omega[0] * 1000.0f)) & 0x00FF0000) >> 16;
    upload_data[37] = ((int32_t)(winch->pose->omega[0] * 1000.0f)) >> 24;

    upload_data[38] = ((int32_t)(winch->pose->omega[1] * 1000.0f)) & 0x000000FF;    
    upload_data[39] = (((int32_t)(winch->pose->omega[1] * 1000.0f)) & 0x0000FF00) >> 8;
    upload_data[40] = (((int32_t)(winch->pose->omega[1] * 1000.0f)) & 0x00FF0000) >> 16;
    upload_data[41] = ((int32_t)(winch->pose->omega[1] * 1000.0f)) >> 24;

    upload_data[42] = ((int32_t)(winch->pose->omega[2] * 1000.0f)) & 0x000000FF;
    upload_data[43] = (((int32_t)(winch->pose->omega[2] * 1000.0f)) & 0x0000FF00) >> 8;
    upload_data[44] = (((int32_t)(winch->pose->omega[2] * 1000.0f)) & 0x00FF0000) >> 16;
    upload_data[45] = ((int32_t)(winch->pose->omega[2] * 1000.0f)) >> 24;

    upload_data[46] = winch->trj_index;



    // 调试代码（已注释，需要时取消注释）
    // 第4路：使用原始编码器 + 圈数跟踪（与 data_process 一致）
    // int32_t m4_now = 0;
    // uint16_t enc4 = ((uint16_t)g_m4_raw[0] << 8) | g_m4_raw[1];
    // if (!m4_inited) {
    //     m4_last_fdbPos = (int16_t)enc4;
    //     m4_round = 0;
    //     m4_inited = 1;
    // } else {
    //     int16_t diff = (int16_t)enc4 - m4_last_fdbPos;
    //     if (diff > 4096) {
    //         m4_round--;
    //     } else if (diff < -4096) {
    //         m4_round++;
    //     }
    //     m4_last_fdbPos = (int16_t)enc4;
    // }
    // int32_t realPos4 = (int32_t)m4_last_fdbPos + (int32_t)m4_round * 8192;
    // float now_pos_deg4 = ((float)realPos4) * (360.0f / 8192.0f) / 36.0f;
    // m4_now = (int32_t)(now_pos_deg4 * 1000.0f);
    // 直接带上第4路最近一次原始8字节（便于判断是否全零/字节位序）
    // for (int i = 0; i < 8; ++i) upload_data[30 + i] = g_m4_raw[i];
    // 调试：用第4路接收计数的低 8 位替代原 trj_index
    // upload_data[42] = (uint8_t)(g_m4_rx_cnt & 0xFF);
    // 调试：附加最近一次接收到的 CAN StdId（小端）
    // upload_data[43] = (uint8_t)(g_last_can_std_id & 0xFF);
    // upload_data[44] = (uint8_t)((g_last_can_std_id >> 8) & 0xFF);

    BSP_UART_Send_DMA(PC_UART, upload_data, sizeof(upload_data));
}

void APP_SendPose()
{
    pose_data[0] = ((int32_t)(winch->poseX_ref * 1000.0f)) & 0x000000FF;
    pose_data[1] = (((int32_t)(winch->poseX_ref * 1000.0f)) & 0x0000FF00) >> 8;
    pose_data[2] = (((int32_t)(winch->poseX_ref * 1000.0f)) & 0x00FF0000) >> 16;
    pose_data[3] = ((int32_t)(winch->poseX_ref * 1000.0f)) >> 24;

    pose_data[4] = ((int32_t)(winch->poseY_ref * 1000.0f)) & 0x000000FF;
    pose_data[5] = (((int32_t)(winch->poseY_ref * 1000.0f)) & 0x0000FF00) >> 8;
    pose_data[6] = (((int32_t)(winch->poseY_ref * 1000.0f)) & 0x00FF0000) >> 16;
    pose_data[7] = ((int32_t)(winch->poseY_ref * 1000.0f)) >> 24;

    BSP_UART_Send_DMA(WHEEL_UART, pose_data, sizeof(pose_data));
}
void APP_Layer_Init()
{
    Winch_Drvier_Init();
    winch = Winch_Create();
    Winch_SetPID(winch);
    wheel = Wheel_Create(winch);
}

void APP_WheelTask(void)
{
    Wheel_Set_Qd();
    Wheel_Motor_Update();
    Wheel_Run_Tau();
    //Stable_Control();
    //Wheel_Test();
}


void APP_WinchTask()
{
    Winch_Calc_Output(winch);
    Winch_Send_Current();
    Winch_Pose_SetZero();
}
//此处需要在freertos里添加新的任务，配置参考原先代码

void APP_StartTrj()
{
    if(winch->mode == Winch_mode_T || winch->mode == Winch_mode_SC || winch->mode == Winch_mode_Lift)
        StartTrj(winch);
    else
        return;
}

void APP_UploadData()
{
    upload_data[0] = 0xAA;
    upload_data[1] = 0x55;

    //姿态（保留 X/Y/Z 角，仅用于基本监测）
    // upload_data[2] = ((int32_t)(winch->pose->euler[0] * 1000.0f)) & 0x000000FF;
    // upload_data[3] = (((int32_t)(winch->pose->euler[0] * 1000.0f)) & 0x0000FF00) >> 8;
    // upload_data[4] = (((int32_t)(winch->pose->euler[0] * 1000.0f)) & 0x00FF0000) >> 16;
